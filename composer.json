{
    "name": "codeq/meilisearch-queueindexer",
    "description": "Asynchronous node indexing for Medienreaktor.Meilisearch via the Flowpack JobQueue.",
    "type": "neos-package",
    "license": "MIT",
    "require": {
        "neos/flow": "^7.0 || ^8.0",
        "neos/content-repository": "^7.0 || ^8.0",
        "flowpack/jobqueue-common": "^3.0 || dev-master",
